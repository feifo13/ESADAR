+
+/* === ESADAR unavailable article view + checkout Prex transfer action === */
+.article-unavailable-page {
+  padding-top: clamp(18px, 3vw, 34px);
+}
+
+.article-unavailable-card {
+  display: grid;
+  grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
+  gap: clamp(18px, 3vw, 38px);
+  align-items: start;
+}
+
+.article-unavailable-card__media {
+  min-width: 0;
+}
+
+.article-unavailable-card__content {
+  min-width: 0;
+  align-self: center;
+}
+
+.article-unavailable-card__content h1 {
+  margin: 0;
+}
+
+.article-unavailable-meta strong {
+  text-transform: none;
+}
+
+.checkout-complete-screen {
+  gap: clamp(16px, 3vw, 28px);
+}
+
+.checkout-complete-payment-card {
+  position: relative;
+  z-index: 1;
+  width: min(100%, 760px);
+  margin: 0 auto;
+}
+
+.checkout-complete-transfer-actions {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 10px;
+  margin: 18px 0;
+}
+
+.checkout-complete-payment-details {
+  display: grid;
+  gap: 10px;
+  margin-top: 14px;
+}
+
+.checkout-complete-payment-row {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 12px;
+  align-items: center;
+  padding: 12px 0;
+  border-top: 1px solid var(--border-soft, rgba(7, 22, 33, 0.12));
+}
+
+.checkout-complete-payment-row span {
+  display: block;
+  color: var(--text-muted, #5f6b75);
+  font-size: 0.78rem;
+  font-weight: 800;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+.checkout-complete-payment-row strong {
+  display: block;
+  margin-top: 4px;
+  overflow-wrap: anywhere;
+}
+
+.checkout-complete-copy-button {
+  min-width: 88px;
+  padding-inline: 12px;
+}
+
+.checkout-complete-bank-instructions {
+  margin-top: 14px;
+  white-space: pre-line;
+}
+
+@media (max-width: 960px) {
+  .article-unavailable-card {
+    grid-template-columns: 1fr;
+  }
+
+  .checkout-complete-transfer-actions,
+  .checkout-complete-transfer-actions .button {
+    width: 100%;
+  }
+
+  .checkout-complete-payment-row {
+    grid-template-columns: 1fr;
+  }
+
+  .checkout-complete-copy-button {
+    width: 100%;
+  }
+}
