# Base app
NODE_ENV=development
PORT=4000
APP_ORIGIN=http://localhost:5173
PUBLIC_SITE_URL=http://localhost:5173
STORE_NAME=ESADAR

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=esadar

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ESADAR
SMTP_REPLY_TO=
SMTP_TLS_REJECT_UNAUTHORIZED=true

# Mercado Pago fallback/env config.
# You can also configure these from /admin/collecting.
MERCADO_PAGO_ENV=test
MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_USER_ID=
MERCADO_PAGO_CHECKOUT_URL=
MERCADO_PAGO_NOTIFICATION_URL=
MERCADO_PAGO_WEBHOOK_SECRET=
