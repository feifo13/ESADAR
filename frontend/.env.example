# ESADAR frontend env example
#
# By default the app uses same-origin URLs:
# - browser calls /api/*
# - assets use /uploads/*
#
# Local dev is handled by the Vite proxy in vite.config.js.
# Sandbox/prod is handled by Nginx proxy rules.

# Usually leave empty.
VITE_API_URL=

# Usually leave empty. The browser uses window.location.origin.
VITE_PUBLIC_SITE_URL=

# Only used by Vite dev server proxy. Not exposed to the browser unless prefixed and referenced.
VITE_DEV_API_PROXY_TARGET=http://localhost:4000
